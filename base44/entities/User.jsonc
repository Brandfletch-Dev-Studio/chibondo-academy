{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "teacher",
        "user"
      ],
      "default": "user"
    },
    "avatar_url": {
      "type": "string",
      "description": "Profile photo URL — set from settings page"
    },
    "referral_code": {
      "type": "string",
      "description": "Custom referral code set by admin or the user themselves"
    },
    "subscription_plan": {
      "type": "string",
      "enum": [
        "free",
        "monthly",
        "quarterly",
        "annual",
        "biannual"
      ],
      "default": "free"
    },
    "total_learning_hours": {
      "type": "number",
      "default": 0,
      "description": "Cumulative learning hours — incremented by lesson completion automation"
    },
    "study_streak": {
      "type": "number",
      "default": 0,
      "description": "Consecutive days with at least one lesson completed"
    },
    "last_study_date": {
      "type": "string",
      "format": "date",
      "description": "ISO date of the last day the student completed a lesson — used to compute streak"
    },
    "phone_number": {
      "type": "string",
      "description": "WhatsApp phone number in international format (e.g. 265995663949)"
    },
    "whatsapp_notifications": {
      "type": "boolean",
      "default": true,
      "description": "Whether the user wants to receive WhatsApp notifications"
    },
    "push_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Whether push notifications are enabled for this user"
    },
    "inapp_notifications": {
      "type": "boolean",
      "default": true,
      "description": "Whether in-app notifications are enabled"
    },
    "full_name": {
      "type": "string",
      "description": "Full name of the user"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address (may be a placeholder for WhatsApp-only users)"
    }
  },
  "rls": {
    "read": {},
    "create": {},
    "update": {
      "$or": [
        { "user_condition": { "role": "admin" } },
        { "user_condition": { "_app_role": "admin" } },
        { "user_condition": { "_app_role": "editor" } },
        { "data.id": "{{user.id}}" }
      ]
    },
    "delete": {
      "$or": [
        { "user_condition": { "role": "admin" } },
        { "user_condition": { "_app_role": "admin" } }
      ]
    }
  }
}
