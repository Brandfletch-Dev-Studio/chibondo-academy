{
  "name": "Enrollment",
  "type": "object",
  "properties": {
    "student_id": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "subject_name": {
      "type": "string"
    },
    "form_id": {
      "type": "string"
    },
    "form_name": {
      "type": "string"
    },
    "progress_percentage": {
      "type": "number",
      "default": 0
    },
    "completed_lessons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_lesson_id": {
      "type": "string"
    },
    "last_accessed": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "completed",
        "paused"
      ],
      "default": "active"
    }
  },
  "required": [
    "student_id",
    "subject_id"
  ],
  "rls": {
    "create": {
      "data.student_id": "{{user.id}}"
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "_app_role": "admin"
          }
        },
        {
          "user_condition": {
            "_app_role": "editor"
          }
        },
        {
          "user_condition": {
            "role": "teacher"
          }
        },
        {
          "data.student_id": "{{user.id}}"
        }
      ]
    },
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "_app_role": "admin"
          }
        },
        {
          "user_condition": {
            "_app_role": "editor"
          }
        },
        {
          "data.student_id": "{{user.id}}"
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}